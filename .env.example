# ShellGuard Environment Configuration
# Copy to .env and fill in your values.

# ─── Database ────────────────────────────────────────────────────────
# PostgreSQL connection string. The app auto-converts to asyncpg driver.
# Default (matches docker-compose): postgresql://shellguard:shellguard@shellguard-db:5432/shellguard
DATABASE_URL=postgresql://shellguard:shellguard@shellguard-db:5432/shellguard
SG_DB_PASS=shellguard

# ─── External Services ──────────────────────────────────────────────
# OpenShell gateway endpoint for sandbox management
OPENSHELL_GATEWAY=http://openshell-gateway:6443

# Open WebUI instance URL and API key for user sync
OPEN_WEBUI_BASE_URL=http://open-webui:8080
OPEN_WEBUI_API_KEY=

# Admin API key for management endpoints (leave empty to disable key auth)
ADMIN_API_KEY=

# ─── Frontend (build-time) ──────────────────────────────────────────
# Supabase project URL and anon key (injected at frontend build time)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Sandbox Proxy ──────────────────────────────────────────────────
# Port that Open Terminal listens on inside each sandbox (default: 8000)
# SANDBOX_PORT=8000
# HTTP proxy timeout in seconds (default: 30)
# PROXY_TIMEOUT=30

# ─── Pool Configuration ─────────────────────────────────────────────
# Number of pre-warmed sandboxes to keep ready (default: 2)
POOL_WARMUP_SIZE=2
# Maximum total sandboxes (default: 20)
POOL_MAX_SANDBOXES=20
# Maximum concurrently active sandboxes (default: 10)
POOL_MAX_ACTIVE=10
# Default sandbox image tag (default: shellguard-sandbox:slim)
DEFAULT_IMAGE_TAG=shellguard-sandbox:slim

# ─── Lifecycle Timeouts (seconds) ───────────────────────────────────
# Idle timeout before suspending active/ready sandboxes (default: 1800 = 30min)
IDLE_TIMEOUT=1800
# Time before destroying suspended sandboxes (default: 86400 = 24h)
SUSPEND_TIMEOUT=86400
# Max time to wait for sandbox startup (default: 120 = 2min)
# STARTUP_TIMEOUT=120
# Max time to wait for sandbox resume (default: 30)
# RESUME_TIMEOUT=30

# ─── Audit ───────────────────────────────────────────────────────────
# Days to retain audit log entries (default: 90)
# AUDIT_RETENTION_DAYS=90

# ─── Server ──────────────────────────────────────────────────────────
# Log level: debug, info, warning, error (default: info)
LOG_LEVEL=info
# CORS allowed origins (default: *)
# CORS_ORIGINS=["*"]

# ─── Metrics ─────────────────────────────────────────────────────────
# Bearer token for /metrics endpoint (leave empty for unauthenticated access)
# METRICS_TOKEN=
