# Open Terminal Orchestrator Environment Configuration
# Copy to .env and fill in your values.

# ─── Database ────────────────────────────────────────────────────────
# PostgreSQL connection string. The app auto-converts to asyncpg driver.
# Default (matches docker-compose): postgresql://oto:oto@oto-db:5432/oto
DATABASE_URL=postgresql://oto:oto@oto-db:5432/oto
SG_DB_PASS=oto

# SQLite fallback (for local dev without Supabase / PostgreSQL):
# DATABASE_URL=sqlite:///./oto.db
# Tables are auto-created on first run. No migrations needed.

# ─── External Services ──────────────────────────────────────────────
# OpenShell gateway endpoint for sandbox management
OPENSHELL_GATEWAY=http://openshell-gateway:6443

# Open WebUI instance URL and API key for user sync
OPEN_WEBUI_BASE_URL=http://open-webui:8080
OPEN_WEBUI_API_KEY=

# Admin API key for management endpoints (leave empty to disable key auth)
ADMIN_API_KEY=

# ─── Frontend (build-time) ──────────────────────────────────────────
# Supabase project URL and anon key (injected at frontend build time).
# When OMITTED the frontend falls back to "local mode" and routes all
# data through the backend REST API with local JWT auth.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ─── Sandbox Container Network ──────────────────────────────────────
# Docker network that sandbox containers are attached to.  Must be the
# same network the OTO container runs on so it can reach sandboxes by IP.
# Default matches the network defined in docker-compose.yml.
SANDBOX_NETWORK=oto-internal

# ─── Sandbox Proxy ──────────────────────────────────────────────────
# Port that Open Terminal listens on inside each sandbox (default: 8000)
# SANDBOX_PORT=8000
# HTTP proxy timeout in seconds (default: 30)
# PROXY_TIMEOUT=30
# API key for Open Terminal instances inside sandboxes. Open Terminal Orchestrator injects
# this when creating sandboxes and includes it when proxying requests.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SANDBOX_API_KEY=

# ─── Pool Configuration ─────────────────────────────────────────────
# Number of pre-warmed sandboxes to keep ready (default: 2)
POOL_WARMUP_SIZE=2
# Maximum total sandboxes (default: 20)
POOL_MAX_SANDBOXES=20
# Maximum concurrently active sandboxes (default: 10)
POOL_MAX_ACTIVE=10
# Default sandbox image tag (default: oto-sandbox:slim)
DEFAULT_IMAGE_TAG=oto-sandbox:slim

# ─── Lifecycle Timeouts (seconds) ───────────────────────────────────
# Idle timeout before suspending active/ready sandboxes (default: 1800 = 30min)
IDLE_TIMEOUT=1800
# Time before destroying suspended sandboxes (default: 86400 = 24h)
SUSPEND_TIMEOUT=86400
# Max time to wait for sandbox startup (default: 120 = 2min)
# STARTUP_TIMEOUT=120
# Max time to wait for sandbox resume (default: 30)
# RESUME_TIMEOUT=30

# ─── Audit ───────────────────────────────────────────────────────────
# Days to retain audit log entries (default: 90)
# AUDIT_RETENTION_DAYS=90

# ─── Server ──────────────────────────────────────────────────────────
# Log level: debug, info, warning, error (default: info)
LOG_LEVEL=info
# CORS allowed origins (default: *)
# CORS_ORIGINS=["*"]

# ─── Metrics ─────────────────────────────────────────────────────────
# Bearer token for /metrics endpoint (leave empty for unauthenticated access)
# METRICS_TOKEN=

# ─── OpenTelemetry ──────────────────────────────────────────────────
# Enable trace propagation from Open WebUI through orchestrator to sandbox
# OTEL_ENABLED=false
# OTLP gRPC exporter endpoint (e.g. Jaeger, Tempo, Datadog agent)
# OTEL_ENDPOINT=http://localhost:4317
# Service name reported in traces
# OTEL_SERVICE_NAME=oto
